# Боевой вариант: приватный файл Яндекс.Диска.
# Токен хранить только на сервере. Не вставлять его в frontend.
YANDEX_DISK_TOKEN=replace_with_real_oauth_token
YANDEX_DISK_PATH=/Loginom/Сводная таблица.json

# Тестовый вариант: публичная ссылка Яндекс.Диска.
# Если YANDEX_DISK_TOKEN задан, backend использует приватный вариант.
YANDEX_PUBLIC_URL=https://disk.yandex.ru/d/X2LAAlT4PyzKCA

# 0 = без кэша. После проверки можно поставить 60-300 секунд.
CACHE_SECONDS=0

# 0 = не подменять боевые данные локальным примером при ошибке источника.
ALLOW_LOCAL_FALLBACK=0

HOST=127.0.0.1
PORT=3000
